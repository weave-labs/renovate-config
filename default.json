{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "autoApprove": true,
  "automergeStrategy": "squash",
  "env": {
    "GOPRIVATE": "github.com/weave-labs/*"
  },
  "extends": [
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":docker",
    ":enableVulnerabilityAlerts",
    ":semanticCommitTypeAll(chore)",
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "schedule:automergeWeekly"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "onboardingConfig": {
    "extends": [
      "github>weave-labs/renovate-config"
    ]
  },
  "packageRules": [
    {
      "description": "Docker Hub mirror images keep their Artifact Registry pull path while Renovate looks up tags from Docker Hub.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "us-central1-docker.pkg.dev/weavelabs-common/dockerhub/**"
      ],
      "overridePackageName": "{{replace 'us-central1-docker\\.pkg\\.dev/weavelabs-common/dockerhub/' '' packageName}}"
    },
    {
      "automerge": true,
      "groupName": "all non-major dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "autoApprove": false,
      "automerge": false,
      "groupName": "github actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Delay npm and PyPI updates so brand-new compromised releases have time to be detected and pulled.",
      "matchDatasources": ["npm", "pypi"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Do not automerge package registry updates that run publish/build tooling.",
      "autoApprove": false,
      "automerge": false,
      "matchDatasources": ["npm", "pypi"],
      "matchPackageNames": [
        "@semantic-release/**",
        "@types/node",
        "build",
        "cycjimmy/semantic-release-action",
        "npm",
        "pnpm",
        "pypa/gh-action-pypi-publish",
        "ruff",
        "semantic-release",
        "setuptools",
        "twine",
        "uv"
      ]
    }
  ],
  "osvVulnerabilityAlerts": true,
  "platformAutomerge": true,
  "rebaseWhen": "conflicted"
}
