{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "allowedEnv": [
    "GOPRIVATE"
  ],
  "autoApprove": true,
  "automergeStrategy": "squash",
  "env": {
    "GOPRIVATE": "github.com/weave-labs/*"
  },
  "extends": [
    ":automergeMinor",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":docker",
    ":enableVulnerabilityAlerts",
    ":semanticCommitTypeAll(chore)",
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "schedule:automergeWeekly"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "vulnerabilityAlerts": {
    "description": "Batch vulnerability fixes into the normal non-major dependency PR instead of opening one security PR per package.",
    "groupName": "all non-major dependencies",
    "groupSlug": "all-non-major-dependencies",
    "commitMessageSuffix": "",
    "vulnerabilityFixStrategy": "highest"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update comment-annotated YAML scalar version pins.",
      "managerFilePatterns": [
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+packageName=(?<packageName>\\S+))?(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s+versioning=(?<versioning>\\S+)\\s*\\n\\s*[A-Za-z0-9_.-]+:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{{versioning}}}"
    },
    {
      "customType": "regex",
      "description": "Update comment-annotated Git ref digest pins in YAML scalars.",
      "managerFilePatterns": [
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>git-refs)\\s+depName=(?<depName>\\S+)\\s+packageName=(?<packageName>\\S+)\\s+currentValue=(?<currentValue>\\S+)\\s*\\n\\s*[A-Za-z0-9_.-]+:\\s*[\"']?(?<currentDigest>[0-9a-f]{40})[\"']?"
      ]
    },
    {
      "customType": "regex",
      "description": "Update comment-annotated Docker ARG version pins, including image tag ARGs.",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+packageName=(?<packageName>\\S+))?(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s+versioning=(?<versioning>\\S+)\\s*\\n\\s*ARG\\s+[A-Z0-9_]+=(?:\\S+:)?(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{{versioning}}}"
    }
  ],
  "onboardingConfig": {
    "extends": [
      "github>weave-labs/renovate-config"
    ]
  },
  "packageRules": [
    {
      "description": "Docker Hub mirror images keep their Artifact Registry pull path while Renovate looks up tags from Docker Hub.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "us-central1-docker.pkg.dev/weavelabs-common/dockerhub/**",
        "us-central1-docker.pkg.dev/weavelabs-common/image/**"
      ],
      "overridePackageName": "{{replace 'us-central1-docker\\.pkg\\.dev/weavelabs-common/(?:dockerhub|image)/' '' packageName}}"
    },
    {
      "description": "Run go mod tidy after Go module updates so go.mod and go.sum stay in sync.",
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "automerge": true,
      "groupName": "all non-major dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "autoApprove": false,
      "automerge": false,
      "groupName": "github actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Keep Weave Labs shared CI refs live so downstream repos inherit central workflow policy.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["weave-labs/ci"],
      "pinDigests": false
    },
    {
      "description": "Delay npm and PyPI updates so brand-new compromised releases have time to be detected and pulled.",
      "matchDatasources": ["npm", "pypi"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Do not automerge package registry updates that run publish/build tooling.",
      "autoApprove": false,
      "automerge": false,
      "matchDatasources": ["npm", "pypi"],
      "matchPackageNames": [
        "@semantic-release/**",
        "@types/node",
        "build",
        "cycjimmy/semantic-release-action",
        "npm",
        "pnpm",
        "pypa/gh-action-pypi-publish",
        "ruff",
        "semantic-release",
        "setuptools",
        "twine",
        "uv"
      ]
    },
    {
      "description": "Do not delay first-party Weave Labs dependency updates.",
      "matchPackageNames": [
        "@weave-labs/**",
        "@weavelabs/**",
        "weave-labs/**",
        "github.com/weave-labs/**"
      ],
      "minimumReleaseAge": "0 days"
    }
  ],
  "osvVulnerabilityAlerts": true,
  "platformAutomerge": true,
  "rebaseWhen": "conflicted"
}
